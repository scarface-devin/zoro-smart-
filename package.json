{
  "name": "solshare-network",
  "version": "0.1.0",
  "description": "SolShare Network — A Soroban-powered Real World Asset (RWA) engine for crowdfunded urban solar arrays with cross-chain wrapping middleware.",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r --filter './apps/*' --filter './packages/**' run build",
    "build:contracts": "pnpm --filter @solshare/contracts run build",
    "build:sdk": "pnpm --filter @solshare/sdk run build",
    "build:web": "pnpm --filter @solshare/web run build",
    "build:api": "pnpm --filter @solshare/api run build",
    "build:indexer": "pnpm --filter @solshare/indexer run build",
    "dev": "pnpm -r --parallel --filter './apps/*' --filter './packages/**' run dev",
    "dev:web": "pnpm --filter @solshare/web run dev",
    "dev:api": "pnpm --filter @solshare/api run dev",
    "dev:indexer": "pnpm --filter @solshare/indexer run dev",
    "test": "pnpm -r --filter './apps/*' --filter './packages/**' run test",
    "test:contracts": "pnpm --filter @solshare/contracts run test",
    "typecheck": "pnpm -r --filter './apps/*' --filter './packages/**' run typecheck",
    "lint": "pnpm -r --filter './apps/*' --filter './packages/**' run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,toml,rs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml,toml,rs}\"",
    "clean": "pnpm -r --filter './apps/*' --filter './packages/**' exec rm -rf dist node_modules .turbo && rm -rf node_modules",
    "deploy:testnet": "tsx tools/scripts/deploy-testnet.ts",
    "deploy:mainnet": "tsx tools/scripts/deploy-mainnet.ts",
    "stellar:setup": "tsx tools/scripts/setup-stellar-env.ts",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/solshare-network/solshare-network.git"
  },
  "keywords": [
    "stellar",
    "soroban",
    "rwa",
    "solar",
    "defi",
    "cross-chain",
    "web3",
    "hackathon"
  ]
}
