# Multi-stage Dockerfile for the @solshare/web dashboard.
FROM node:22-alpine AS deps
WORKDIR /app
RUN apk add --no-cache libc6-compat
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* tsconfig.base.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
COPY packages/sdk/package.json ./packages/sdk/
RUN corepack enable && pnpm install --frozen-lockfile --filter @solshare/web...

FROM node:22-alpine AS build
WORKDIR /app
COPY --from=deps /app /app
COPY packages/shared ./packages/shared
COPY packages/sdk ./packages/sdk
COPY apps/web ./apps/web
RUN pnpm --filter @solshare/shared run build || true
RUN pnpm --filter @solshare/sdk run build || true
RUN pnpm --filter @solshare/web run build

FROM nginx:1.27-alpine AS run
COPY --from=build /app/apps/web/dist /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
