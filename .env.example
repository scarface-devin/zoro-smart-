# ============================================================================
# SolShare Network — Environment Configuration
# Copy to .env and fill in real values. Never commit real secrets.
# ============================================================================

# ============ Stellar Network ============
# Pick one: FUTURENET | TESTNET | PUBLIC | STANDALONE
STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org

# ============ Source-of-funds / Deployer ============
# 64-character hex string starting with 'S'... (Stellar secret seed)
SOLSHARE_DEPLOYER_SECRET=
SOLSHARE_ADMIN_PUBLIC=GAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# ============ Cross-chain Bridge ============
BRIDGE_VALIDATOR_SECRET=
BRIDGE_VALIDATOR_PUBLIC=
SUPPORTED_SOURCE_CHAINS=ethereum,sepolia,solana,polygon,amoy
ETHEREUM_RPC_URL=https://eth.llamarpc.com
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
POLYGON_RPC_URL=https://polygon-rpc.com
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ============ API / Middleware ============
API_PORT=4000
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:5173
API_LOG_LEVEL=info
API_JWT_SECRET=replace-with-long-random-string

# ============ Indexer ============
INDEXER_POLL_INTERVAL_MS=4000
INDEXER_START_LEDGER=latest
INDEXER_DATABASE_URL=postgres://solshare:solshare@localhost:5432/solshare
INDEXER_REDIS_URL=redis://localhost:6379

# ============ Database ============
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=solshare
POSTGRES_PASSWORD=solshare
POSTGRES_DB=solshare

# ============ Web (Frontend) ============
VITE_API_BASE_URL=http://localhost:4000
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_BRIDGE_EXPLORER_URL=http://localhost:4000/api/bridge

# ============ Observability ============
SENTRY_DSN=
DATADOG_API_KEY=
