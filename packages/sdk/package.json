{
  "name": "@solshare/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK that bundles Soroban RPC, Horizon, and SolShare smart-contract invocations into a single ergonomic client.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./contracts": "./src/contracts/index.ts",
    "./wallet": "./src/wallet.ts",
    "./stream": "./src/stream.ts",
    "./horizon": "./src/horizon.ts",
    "./soroban": "./src/soroban.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run"
  },
  "dependencies": {
    "@solshare/shared": "workspace:*",
    "@stellar/freighter-api": "^5.0.0",
    "@stellar/stellar-sdk": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
