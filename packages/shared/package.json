{
  "name": "@solshare/shared",
  "version": "0.1.0",
  "description": "Shared cross-package types, constants, and formatters for the SolShare Network polyrepo.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./constants": "./src/constants.ts",
    "./errors": "./src/errors.ts",
    "./format": "./src/format.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2.1.2"
  }
}
